# Скопируйте в .env и заполните. Это весь обязательный минимум —
# всё остальное (БД, подключение панели) настраивается мастером в Telegram.

# Токен бота от @BotFather
BOT_TOKEN=

# Ваш Telegram ID (узнать: @userinfobot). Только этому ID доступен мастер установки.
ADMIN_TELEGRAM_ID=

# Необязательно: ключ шифрования секретов в БД.
# Если оставить пустым — сгенерируется автоматически в DATA_DIR/secret.key.
SECRET_KEY=
